class Env {
  /// The URL of the shared Supabase project.
  /// Can be injected via: --dart-define=SUPABASE_URL=your_url
  static const String supabaseUrl = String.fromEnvironment(
    'SUPABASE_URL',
    defaultValue: 'YOUR_SUPABASE_URL_HERE',
  );

  /// The public anon key of the shared Supabase project.
  /// Can be injected via: --dart-define=SUPABASE_ANON_KEY=your_key
  static const String supabaseAnonKey = String.fromEnvironment(
    'SUPABASE_ANON_KEY',
    defaultValue: 'YOUR_SUPABASE_ANON_KEY_HERE',
  );
}
